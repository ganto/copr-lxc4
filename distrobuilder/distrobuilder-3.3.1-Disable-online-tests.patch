-			"",
-			keys,
-			keyserver,
-			false,
-		},
-		{
-			"no keys",
-			filepath.Join(testdataDir, "testfile"),
-			filepath.Join(testdataDir, "testfile.sig"),
-			[]string{},
-			keyserver,
-			true,
-		},
-		{
-			"invalid key",
